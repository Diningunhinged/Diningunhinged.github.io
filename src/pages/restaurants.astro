---
import MainLayout from "../layouts/MainLayout.astro";
import ReviewCard from "../components/ReviewCard.astro";
import { client } from "../lib/sanity";
import { urlFor } from "../lib/image";

const reviews = await client.fetch(`
  *[_type == "restaurantReview"] | order(publishedDate desc){
    title,
    rating,
    excerpt,
    heroImage,
    "slug": slug.current,
    venue->{
      cuisine
    }
  }
`);
---

<MainLayout title="Restaurants | Dining Unhinged">

  <section>

    <h1>Restaurants</h1>

    <p class="featured-summary">
      Every restaurant we've reviewed. No paid rankings. No sponsored placements.
      Just honest opinions and memorable meals.
    </p>

    <div class="restaurant-grid">

      {reviews.map((review: any) => (
        <ReviewCard
          title={review.title}
          rating={review.rating}
          category={review.venue?.cuisine ?? ""}
          excerpt={review.excerpt}
          image={urlFor(review.heroImage).width(800).url()}
          url={`/restaurants/${review.slug}`}
        />
      ))}

    </div>

  </section>

</MainLayout>