---
import MainLayout from "../layouts/MainLayout.astro";
import ReviewCard from "../components/ReviewCard.astro";
import { client } from "../lib/sanity";
import { urlFor } from "../lib/image";

const cocktails = await client.fetch(`
  *[_type == "cocktailReview"] | order(publishedDate desc){
    title,
    rating,
    storyHook,
    heroImage,
    "slug": slug.current,
    venue->{
      name,
      city,
      province
    }
  }
`);
---

<MainLayout title="Cocktails | Dining Unhinged">

  <section>

    <h1>Cocktails</h1>

    <p class="featured-summary">
      Great cocktails deserve great stories. From timeless classics to modern creations,
      Dining Unhinged explores exceptional cocktails, fine spirits, and the people who
      make them worth remembering.
    </p>

    <div class="restaurant-grid">

      {cocktails.map((cocktail: any) => (
        <ReviewCard
          title={cocktail.title}
          rating={cocktail.rating ?? 5}
          category={`${cocktail.venue?.name ?? ""} • ${cocktail.venue?.city ?? ""}, ${cocktail.venue?.province ?? ""}`}
          excerpt={cocktail.storyHook}
          image={urlFor(cocktail.heroImage).width(800).url()}
          url={`/cocktails/${cocktail.slug}`}
        />
      ))}

    </div>

  </section>

</MainLayout>