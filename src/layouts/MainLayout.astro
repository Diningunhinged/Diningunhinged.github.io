---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
}

const {
  title = "Dining Unhinged | Food Reviews with Excellent Taste and Questionable Restraint",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <meta
      name="description"
      content="Dining Unhinged is an independent restaurant review publication featuring honest reviews, exceptional cocktails, and unforgettable dining experiences."
    />

    <link rel="icon" href="/favicon.svg" />

  </head>

  <body>

    <Header />

    <main>

      <slot />

    </main>

    <Footer />

  </body>

</html>